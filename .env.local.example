# Database (Prisma loads .env.local via npm scripts — encode @ in password as %40)
# Supabase: use Session pooler (port 5432) from Dashboard → Connect, not db.*.supabase.co if P1001
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
# Optional: direct host for migrations (same as DATABASE_URL if using session pooler)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="noreply@beyondbordersconference.tn"

# Storage
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Payments (optional Stripe)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=""

# Monitoring
SENTRY_DSN=""

# Conference config
NEXT_PUBLIC_CONFERENCE_DATE="2026-07-15T09:00:00+01:00"
NEXT_PUBLIC_REGISTRATION_OPEN_DATE="2026-07-01T00:00:00+01:00"
NEXT_PUBLIC_REGISTRATION_CLOSE_DATE="2026-07-13T23:59:59+01:00"
